        private void btnShowMovies_Click(object sender, EventArgs e)
        {
            try
            {
                SqlConnection con = new SqlConnection("Data Source = localhost; Initial Catalog = CinemaProject; Integrated Security = True; Encrypt = False");
                int hallNumber = int.Parse(SMIH_TxtboxHallNo.Text);

                SqlCommand cmd = new SqlCommand("GetMoviesInHall", con);
                cmd.CommandType = CommandType.StoredProcedure;
                cmd.Parameters.AddWithValue("@HallNumber", hallNumber);

                SqlDataAdapter da = new SqlDataAdapter(cmd);
                DataTable dt = new DataTable();

                da.Fill(dt);

                dataGridView1.DataSource = dt;
            }
            catch (Exception ex)
            {
                MessageBox.Show(ex.Message);
            }

        }

        private void textBox1_TextChanged(object sender, EventArgs e)
        {

        }

        private void btnCheckCapacity_Click(object sender, EventArgs e)
        {
            try
            {
                SqlConnection con = new SqlConnection("Data Source = localhost; Initial Catalog = CinemaProject; Integrated Security = True; Encrypt = False");
                int hallNumber = int.Parse(SHC_TxtboxHallNo.Text);

                SqlCommand cmd = new SqlCommand("SELECT dbo.CheckHallCapacity(@HallNumber)", con);
                cmd.Parameters.AddWithValue("@HallNumber", hallNumber);

                con.Open();
                object result = cmd.ExecuteScalar();
                con.Close();

                if (result != null && (int)result == -1)
                    SHC_lbCapacityResult.Text = "Hall not found!";
                else if (result != null)
                    SHC_lbCapacityResult.Text = "Capacity = " + result.ToString();
                else
                    SHC_lbCapacityResult.Text = "Hall not found!";
            }
            catch (Exception ex)
            {
                MessageBox.Show(ex.Message);
            }

        }

        private void btnUpdateHall_Click(object sender, EventArgs e)
        {
            try
            {
                SqlConnection con = new SqlConnection("Data Source = localhost; Initial Catalog = CinemaProject; Integrated Security = True; Encrypt = False");
                int hallNumber = int.Parse(UH_TxtboxHallNo.Text);
                int capacity = int.Parse(UH_TxtboxNewHallCap.Text);

                SqlCommand cmd = new SqlCommand("UpdateHall", con);
                cmd.CommandType = CommandType.StoredProcedure;

                cmd.Parameters.AddWithValue("@HallNumber", hallNumber);
                cmd.Parameters.AddWithValue("@HallCapacity", capacity);

                con.Open();
                cmd.ExecuteNonQuery();
                con.Close();

                MessageBox.Show("Hall Updated Successfully!");
            }
            catch (Exception ex)
            {
                MessageBox.Show(ex.Message);
            }

        }

      
    }
}
