-- Since we have on average 200 seats per hall, hence we need to generate 200 seats for 10 halls:

DECLARE @hall INT = 1;
DECLARE @seat INT;

WHILE @hall <= 10
BEGIN
    SET @seat = 1;
    WHILE @seat <= 200
    BEGIN
        INSERT INTO Seats (HallNumber, SeatNumber, SeatArrangement)
        VALUES (@hall, @seat, CONCAT('Hall ', @hall, ' Seat ', @seat));
        SET @seat = @seat + 1; -- Seats incrementation
    END;
    SET @hall = @hall + 1;  -- Hall incrementation
END;
