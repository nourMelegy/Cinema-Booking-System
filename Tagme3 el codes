-- FN7: Check if a seat is taken (Booked)
CREATE FUNCTION IsSeatTaken (@HallNumber INT, @SeatNumber INT)
RETURNS VARCHAR(10)
AS
BEGIN
    DECLARE @Result VARCHAR(10);
    IF EXISTS (
        SELECT 1 FROM Ticket
        WHERE HallNumber = @HallNumber
          AND SeatNumber = @SeatNumber
          AND TicketStatus = 'Booked'
    )
        SET @Result = 'Taken';
    ELSE
        SET @Result = 'Available';
    RETURN @Result;
END;
GO
