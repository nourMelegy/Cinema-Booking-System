-- ============================================================================
-- CINEMA TICKET BOOKING SYSTEM - FULL ORGANIZED SCRIPT
-- NOTE: Tables [admin] and [transactions] are assumed to already exist 
--       in the database (pre-created). This script builds everything else.
-- ============================================================================

-- ============================================================================
-- SECTION 1: TABLE CREATION (ordered by dependencies)
-- ============================================================================

-- 1.1 Hall Table (no dependencies)
CREATE TABLE Hall (
    HallNumber   INT NOT NULL PRIMARY KEY,
    HallCapacity INT
);

-- 1.2 Movie Table (no dependencies)
CREATE TABLE Movie (
    EIDR       VARCHAR(20)    PRIMARY KEY,
    Title      VARCHAR(100)   NOT NULL,
    Duration   INT            NOT NULL,
    Price      DECIMAL(8, 2)  NOT NULL,
    TimeSlots  VARCHAR(100),
    AgeRating  VARCHAR(10)    NOT NULL,
    CONSTRAINT CK_Price     CHECK (Price > 0),
    CONSTRAINT CK_Duration  CHECK (Duration > 0),
    CONSTRAINT CK_AgeRating CHECK (AgeRating IN ('G', 'PG', 'PG-13', 'R', '+13', '+18'))
);

-- 1.3 Movie_Genre Table (depends on Movie)
CREATE TABLE Movie_Genre (
    EIDR  VARCHAR(20),
    Genre VARCHAR(50) NOT NULL,
    PRIMARY KEY (EIDR, Genre),
    FOREIGN KEY (EIDR) REFERENCES Movie(EIDR) ON DELETE CASCADE ON UPDATE CASCADE,
    CONSTRAINT CK_Genre CHECK (Genre IN (
        'Action', 'Comedy', 'Drama', 'Horror', 'Romance',
        'Thriller', 'Sci-Fi', 'Animation', 'Adventure', 'Documentary'
    ))
);

-- 1.4 Displayed_In Table (depends on Movie, Hall)
CREATE TABLE Displayed_in (
    MOEIDR  VARCHAR(20),
    HNumber INT,
    FOREIGN KEY (MOEIDR)  REFERENCES Movie(EIDR),
    FOREIGN KEY (HNumber) REFERENCES Hall(HallNumber),
    PRIMARY KEY (MOEIDR, HNumber)
);

-- 1.5 Seats Table (depends on Hall)
CREATE TABLE Seats (
    HallNumber      INT,
    SeatNumber      INT,
    SeatArrangement VARCHAR(50),
    CONSTRAINT PK_Seats PRIMARY KEY (HallNumber, SeatNumber),
    CONSTRAINT FK_Seats_Hall     FOREIGN KEY (HallNumber) REFERENCES Hall(HallNumber),
    CONSTRAINT CHK_Seats_HallNumber    CHECK (HallNumber BETWEEN 1 AND 10),
    CONSTRAINT CHK_Seats_SeatNumber    CHECK (SeatNumber > 0),
    CONSTRAINT CHK_Seats_SeatArrangement CHECK (SeatArrangement IN (
        'Front-Right', 'Front-Left', 'Front-Center',
        'Back-Right',  'Back-Left',  'Back-Center'
    )),
    CONSTRAINT DF_Seats_SeatArrangement DEFAULT 'Standard' FOR SeatArrangement
);

-- 1.6 Show Table (depends on admin — pre-existing)
CREATE TABLE [Show] (
    [show_Number]   INT            PRIMARY KEY,
    [Price]         DECIMAL(10, 2) NOT NULL,
    [Showtime]      DATETIME       NOT NULL,
    [show_admin_id] INT            NOT NULL,
    CONSTRAINT CK_Show_Price_Positive CHECK ([Price] > 0),
    CONSTRAINT fk_show_admin_id FOREIGN KEY (show_admin_id)
        REFERENCES admin(admin_id) ON DELETE NO ACTION
);

-- 1.7 Located_In Table (depends on Hall, Show)
CREATE TABLE [Located_In] (
    HNumber  INT NOT NULL,
    SHNumber INT NOT NULL,
    CONSTRAINT fk_HNumber  FOREIGN KEY (HNumber)  REFERENCES Hall(HallNumber) ON UPDATE CASCADE,
    CONSTRAINT fk_SHNumber FOREIGN KEY (SHNumber) REFERENCES [Show](show_Number)
);

-- 1.8 Customer Table (no dependencies)
CREATE TABLE [Customer] (
    [customer_ID] INT PRIMARY KEY,
    [fname]        NVARCHAR(100),
    [lname]        NVARCHAR(100),
    [email]       NVARCHAR(100) UNIQUE,
    [password]    NVARCHAR(100)
);

-- 1.9 CustomerPhone Table (depends on Customer)
CREATE TABLE CustomerPhone (
    phone_id     INT PRIMARY KEY,
    customer_id  INT,
    phone_number NVARCHAR(20),
    FOREIGN KEY (customer_id) REFERENCES Customer(customer_ID)
);

-- 1.10 Payment Table (no dependencies)
Alter TABLE [payment] add [Payment_Method] NVARCHAR(50);
  Alter TABLE [payment] add  [Amount] MONEY;
   Alter TABLE [payment] add [status] NCHAR(15)


-- 1.11 Booking Table (depends on Show, Customer, Payment)
CREATE TABLE [Booking] (
    [Booking_ID]     INT          PRIMARY KEY,
    [Booking_Status] NVARCHAR(15),
    [Total_Amount]   MONEY,
    [Booking_date]   DATETIME,
    [B_shownumber]   INT          NOT NULL,
    [Customer_ID]    INT          NOT NULL,
    [Payment_ID]     INT          NOT NULL,
    CONSTRAINT FK_Booking_Show     FOREIGN KEY ([B_shownumber]) REFERENCES [Show]([show_Number]),
    CONSTRAINT FK_Booking_Customer FOREIGN KEY ([Customer_ID])  REFERENCES [Customer]([customer_ID]),
    CONSTRAINT FK_Booking_Payment  FOREIGN KEY ([Payment_ID])   REFERENCES [payment]([payment_id]),
    CONSTRAINT UQ_Booking_Payment  UNIQUE ([Payment_ID])
);

-- 1.12 Ticket Table (depends on Booking, Seats)
CREATE TABLE [Ticket] (
    [TicketID]     INT          PRIMARY KEY,
    [TicketStatus] VARCHAR(50)  CONSTRAINT CHK_Ticket_Status   CHECK (TicketStatus IN ('Booked', 'Cancelled', 'Pending')),
    [SeatType]     VARCHAR(50)  CONSTRAINT CHK_Ticket_SeatType CHECK (SeatType IN ('Standard', 'VIP', 'Gold', 'Accessible')),
    [SeatNumber]   INT,
    [HallNumber]   INT,
    [BookingID]    INT,
    [TBooking_ID]  INT          NOT NULL,
    CONSTRAINT FK_Ticket_Booking FOREIGN KEY ([TBooking_ID]) REFERENCES [Booking]([Booking_ID]),
    CONSTRAINT FK_Ticket_Seats   FOREIGN KEY (SeatNumber, HallNumber) REFERENCES Seats(SeatNumber, HallNumber),
    CONSTRAINT FK_Ticket_Booking2 FOREIGN KEY (BookingID)   REFERENCES Booking(Booking_ID),
    CONSTRAINT CHK_Ticket_HallNumber CHECK (HallNumber BETWEEN 1 AND 10),
    CONSTRAINT CHK_Ticket_BookingID  CHECK (BookingID > 0),
    CONSTRAINT DF_Ticket_Status DEFAULT 'Pending' FOR TicketStatus
);


