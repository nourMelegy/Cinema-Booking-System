-- SP8: Cancel a booking and void its payment (with transaction)
CREATE PROCEDURE cancel_booking
    @bookingid INT
AS
BEGIN
    DECLARE @PayID INT;

    SELECT @PayID = Payment_ID
    FROM Booking
    WHERE Booking_ID = @bookingid;

    BEGIN TRANSACTION;
    BEGIN TRY
        UPDATE Booking
        SET Booking_Status = 'Cancelled'
        WHERE Booking_ID = @bookingid;

        UPDATE payment
        SET status = 'Voided'
        WHERE payment_id = @PayID;

        COMMIT TRANSACTION;
    END TRY
    BEGIN CATCH
        ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END;
GO

-- SP9: Update payment method for a booking
CREATE PROCEDURE sp_UpdatePaymentMethod
    @BookingID INT,
    @NewMethod NVARCHAR(50)
AS
BEGIN
    UPDATE payment
    SET Payment_Method = @NewMethod
    FROM payment P
    JOIN Booking B ON P.payment_id = B.Payment_ID
    WHERE B.Booking_ID = @BookingID;
END;
GO

-- SP10: Schedule a show in a hall
CREATE PROCEDURE SP_Schedule_show
    @Hall_num INT,
    @SHNumber INT,
    @time     DATETIME,
    @adminID  INT,
    @price    DECIMAL(10,2)
AS
BEGIN
    IF EXISTS (SELECT * FROM [Show] WHERE show_Number = @SHNumber)
    BEGIN
        PRINT 'ERROR: Show Number ' + CAST(@SHNumber AS VARCHAR) + ' already exists.'
    END
    ELSE IF EXISTS (
        SELECT 1 FROM [Located_In] L
        JOIN [Show] S ON L.SHNumber = S.show_Number
        WHERE L.HNumber = @Hall_num AND S.Showtime = @time
    )
    BEGIN
        PRINT 'This time in this hall is fully booked'
    END
    ELSE
    BEGIN
        INSERT INTO [Show] (show_Number, Price, Showtime, show_admin_id)
        VALUES (@SHNumber, @price, @time, @adminID);

        INSERT INTO [Located_In] (SHNumber, HNumber)
        VALUES (@SHNumber, @Hall_num);

        PRINT 'Scheduling Successful'
    END
END;
GO

-- SP11: Delete a scheduled show
CREATE PROCEDURE DELETE_Scheduled_show
    @Hall_num INT,
    @SHNumber INT,
    @time     DATETIME,
    @adminID  INT
AS
BEGIN
    IF NOT EXISTS (SELECT 1 FROM [Show] WHERE show_Number = @SHNumber)
    BEGIN
        PRINT CAST(@SHNumber AS VARCHAR) + ' does not exist.'
    END
    ELSE IF NOT EXISTS (
        SELECT 1 FROM [Located_In] L
        JOIN [Show] S ON L.SHNumber = S.show_Number
        WHERE L.HNumber = @Hall_num AND S.Showtime = @time
    )
    BEGIN
        PRINT 'This time in this hall doesn''t exist'
    END
    ELSE
    BEGIN
        DELETE FROM [Located_In] WHERE SHNumber = @SHNumber;
        DELETE FROM [Show]       WHERE show_Number = @SHNumber;
        PRINT 'Show removed'
    END
END;
GO

