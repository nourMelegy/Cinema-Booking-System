-- SP1: Update movie price by percentage
CREATE PROCEDURE UpdateMoviePrice
    @MovieEIDR       VARCHAR(20),
    @PricePercentage DECIMAL(5,2)
AS
BEGIN
    UPDATE Movie
    SET Price = Price + (Price * @PricePercentage / 100)
    WHERE EIDR = @MovieEIDR;
END;
GO

