-- FN1: Check hall capacity
CREATE FUNCTION CheckHallCapacity (@HallNumberParameter INT)
RETURNS INT
AS
BEGIN
    DECLARE @ReturnHallCapacity INT;
    SELECT @ReturnHallCapacity = HallCapacity
    FROM Hall
    WHERE HallNumber = @HallNumberParameter;
    RETURN @ReturnHallCapacity;
END;
GO

-- FN2: Get daily confirmed revenue
CREATE FUNCTION fn_getDailyRevenue (@Target_data DATE)
RETURNS MONEY
AS
BEGIN
    DECLARE @total MONEY;
    SELECT @total = SUM(Total_Amount)
    FROM Booking
    WHERE CAST(Booking_date AS DATE) = @Target_data
      AND Booking_Status = 'Confirmed';
    RETURN ISNULL(@total, 0);
END;
GO

-- FN3: Get combined booking + payment status
CREATE FUNCTION get_payment_status (@BookingID INT)
RETURNS NVARCHAR(30)
AS
BEGIN
    DECLARE @pstatus NVARCHAR(50);
    DECLARE @Bstatus NVARCHAR(50);
    SELECT @pstatus = p.status, @Bstatus = Booking_Status
    FROM payment p
    JOIN Booking b ON b.Payment_ID = p.payment_id
    WHERE b.Booking_ID = @BookingID;
    RETURN @Bstatus + ' ' + @pstatus;
END;
GO

