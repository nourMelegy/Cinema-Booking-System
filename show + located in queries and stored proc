SELECT 
    H.HallNumber,
    H.HallCapacity,
    S.show_Number,
    S.Price,
    S.[Showtime]
FROM Hall H
JOIN Located_In L ON H.HallNumber = L.HNumber
JOIN [Show] S     ON L.SHNumber = S.show_Number
ORDER BY H.HallNumber, S.[Showtime];
SELECT 
    S.show_Number, 
    S.Price, 
    S.[Showtime]
FROM [Show] S
JOIN [Located_In] L ON S.show_Number = L.SHNumber
WHERE L.HNumber = 1; 





/*stored procedure for schedulig*/

CREATE PROCEDURE SP_Schedule_show
@Hall_num int,
@SHNumber int,
@time datetime,
@adminID int ,
@price decimal
AS
BEGIN
IF EXISTS (SELECT * FROM [Show] WHERE show_Number = @SHNumber)
    BEGIN
        PRINT 'ERROR: Show Number ' + CAST(@SHNumber AS VARCHAR) + ' already exists.'
    END
    ELSE
IF EXISTS (
    SELECT 1 FROM [Located_In] L
    JOIN [Show] S ON L.SHNumber = S.show_Number
    WHERE L.HNumber = @Hall_num
    AND S.Showtime = @time
)
BEGIN
 PRINT'This time in this hall is fully booked'
END 
ELSE  
BEGIN 
insert into [Show] (show_Number,Price,Showtime,show_admin_id)
values(@SHNumber,@price,@time,@adminID)
insert into [Located_In] (SHNumber,HNumber)
values(@SHNumber,@Hall_num)
PRINT'Scheduling Successsful'
END
END
GO




/*for deleting shows*/
CREATE PROCEDURE DELETE_Scheduled_show
@Hall_num int,
@SHNumber int,
@time datetime,
@adminID int 
AS
BEGIN
IF NOT EXISTS (SELECT 1 FROM [Show] WHERE show_Number = @SHNumber)
    BEGIN
        PRINT CAST(@SHNumber AS VARCHAR) + ' does not exist.'
    END
ELSE IF Not EXISTS (
    SELECT 1 FROM [Located_In] L
    JOIN [Show] S ON L.SHNumber = S.show_Number
    WHERE L.HNumber = @Hall_num
    AND S.Showtime = @time
)
BEGIN
    PRINT'This time in this hall doesnt exist'
END 

ELSE  
BEGIN 
delete from [Located_In] WHERE SHNumber = @SHNumber
delete from [Show] WHERE show_Number =@SHNumber
PRINT'show removed'
END
END
GO

